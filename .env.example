# SOMA keypair secret key (Base58-encoded Ed25519 secret key)
# Generate one by running `uv run score <url>` without this set — it will print a key for you.
SOMA_SECRET_KEY=

# HuggingFace token — required to access bigcode/the-stack-v2-dedup
# Create one at https://huggingface.co/settings/tokens
HF_TOKEN=

# AWS credentials — required to download source files from the Software Heritage S3 bucket
# Also used to upload scored data to your S3-compatible bucket (e.g. Cloudflare R2)
# Create an IAM user with read access, then generate an access key at
# https://console.aws.amazon.com/iam/ → Users → Security credentials → Create access key
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3-compatible bucket for uploading scored data (e.g. Cloudflare R2, MinIO)
# S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY — credentials for the upload bucket
# S3_ENDPOINT_URL is optional — set it for non-AWS providers (e.g. https://<account>.r2.cloudflarestorage.com)
# S3_PUBLIC_URL is optional — the public base URL for the bucket (e.g. https://pub-xxx.r2.dev)
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
S3_PUBLIC_URL=