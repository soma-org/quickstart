# SOMA keypair secret key ( secret key)
SOMA_SECRET_KEY=

# HuggingFace token — required to access bigcode/the-stack-v2-dedup
# Create one at https://huggingface.co/settings/tokens
# You must also approve access to the gated dataset at:
# https://huggingface.co/datasets/bigcode/the-stack-v2-dedup
HF_TOKEN=

# S3-compatible bucket for uploading model weights and submission data
# Cloudflare R2 is recommended (free egress, simple setup):
#   1. Create a bucket at https://dash.cloudflare.com → R2
#   2. Create an R2 API token with read/write permissions
#   3. Fill in the values below
# AWS S3 and GCS (with HMAC keys) also work.
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
S3_PUBLIC_URL=